# ═══════════════════════════════════════════════════════════════
#  CodeRedEnv — API Configuration (.env.sample)
#  Copy to .env and fill in real values.
#  For HF Spaces: set API keys via HF Secrets UI (Settings → Repo secrets),
#  not in this file.
# ═══════════════════════════════════════════════════════════════

# ── Provider Priority: OPENAI → ANTHROPIC → HF_FALLBACK ──────
#    Activate one by setting its API key.

# ── 1. OPENAI-compatible (OpenRouter / Groq / etc.) ───────────
#    Set OPENAI_API_KEY to activate. Priority #1.
OPENAI_API_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL_NAME=qwen/qwen3.6-plus
OPENAI_API_KEY=

# ── 2. ANTHROPIC (OpusCode / Anthropic direct) ───────────────
#    Set ANTHROPIC_API_KEY to activate. Priority #2 (fallback).
ANTHROPIC_API_BASE_URL=https://claude.opuscode.pro/api
ANTHROPIC_MODEL_NAME=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# ── 3. HUGGINGFACE FALLBACK ───────────────────────────────────
#    Always available when neither of the above keys is set.
HF_TOKEN=

# ── Benchmark ─────────────────────────────────────────────────
BENCHMARK=codered_env
TASK_NAME=task1
MAX_STEPS=30
SUCCESS_THRESHOLD=0.2

# ── Docker / HF Spaces ─────────────────────────────────────────
#    Image name for local Docker builds.
LOCAL_IMAGE_NAME=codered-env:latest

#    HF Space repo (used in push scripts).
HF_SPACE_REPO=darshshah1012/coderedenv
